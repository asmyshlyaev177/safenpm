{
  "name": "safenpm",
  "version": "0.1.0",
  "description": "Sandbox npm/pnpm/yarn/bun install with bwrap (Linux) or Docker (macOS) to keep secrets in the working directory and host $HOME out of reach of postinstall scripts.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "safenpm-setup": "install.sh"
  },
  "main": "dist/safenpm.cjs",
  "module": "dist/safenpm.mjs",
  "exports": {
    ".": {
      "import": "./dist/safenpm.mjs",
      "require": "./dist/safenpm.cjs"
    }
  },
  "files": [
    "dist/safenpm.mjs",
    "dist/safenpm.mjs.map",
    "dist/safenpm.cjs",
    "dist/safenpm.cjs.map",
    "install.sh",
    "uninstall.sh",
    "lib/rcedit.sh",
    "README.md",
    ".nvmrc"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepack": "node scripts/build.mjs",
    "test": "node --test 'tests/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "check": "eslint .",
    "fix": "eslint . --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
