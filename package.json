{
  "name": "ringfence",
  "version": "0.2.0",
  "description": "Sandbox npm/pnpm/yarn/bun install with bwrap (Linux) or Docker (macOS) to keep secrets in the working directory and host $HOME out of reach of postinstall scripts.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://ringfence.pages.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asmyshlyaev177/ringfence.git"
  },
  "bugs": {
    "url": "https://github.com/asmyshlyaev177/ringfence/issues"
  },
  "author": {
    "name": "Alexander Smyshlyaev",
    "email": "asmyshlyaev177@gmail.com",
    "url": "https://asmyshlyaev177.dev/"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "tag": "latest",
    "provenance": true
  },
  "keywords": [
    "sandbox",
    "security",
    "npm",
    "pnpm",
    "yarn",
    "bun",
    "install",
    "bubblewrap",
    "bwrap",
    "postinstall",
    "supply-chain",
    "supply chain attack",
    "worm",
    "secrets",
    "credentials",
    "protection",
    "docker",
    "isolation",
    "lifecycle script",
    "anti Shai-Hulud"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.0.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "husky"
    ]
  },
  "bin": {
    "ringfence": "dist/ringfence.mjs",
    "ringfence-setup": "install.sh",
    "ringfence-uninstall": "uninstall.sh",
    "ringfence-init": "scripts/init.cjs"
  },
  "main": "dist/ringfence.cjs",
  "module": "dist/ringfence.mjs",
  "exports": {
    ".": {
      "import": "./dist/ringfence.mjs",
      "require": "./dist/ringfence.cjs"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist/ringfence.mjs",
    "dist/ringfence.mjs.map",
    "dist/ringfence.cjs",
    "dist/ringfence.cjs.map",
    "install.sh",
    "uninstall.sh",
    "lib/rcedit.sh",
    "scripts/postinstall.mjs",
    "scripts/init.cjs",
    "scripts/bootstrap-template.cjs",
    "README.md",
    ".nvmrc"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepack": "node scripts/build.mjs",
    "test": "if [ ! -f /.dockerenv ] && [ -z \"$CI\" ]; then echo 'ERROR: Tests modify host files under $HOME and MUST run inside Docker.'; echo '  Run: npm run test:docker'; echo '  Or: docker build -t ringfence-test -f tests/Dockerfile . && docker run --rm --privileged ringfence-test'; exit 1; fi && node --experimental-strip-types --test 'tests/**/*.test.ts'",
    "test:docker": "docker build -t ringfence-test -f tests/Dockerfile . && docker run --rm --privileged ringfence-test",
    "typecheck": "tsc --noEmit",
    "check": "eslint .",
    "fix": "eslint . --fix",
    "prepare": "test -d .git && husky || true",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
