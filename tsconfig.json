{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["esnext"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "bin/**/*.ts",
    "lib/**/*.ts",
    "tests/**/*.test.ts",
    "tests/*.mjs",
    "scripts/postinstall.mjs"
  ],
  "exclude": ["tests/comprehensive-helpers.ts", "tests/comprehensive-*.test.ts"]
}
